# ── Imboni Backend environment ────────────────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# `python-decouple` reads these; types are cast in settings.py.

# ── Core ──────────────────────────────────────────────────────────────────────
# Generate a fresh key for production:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
THE_SECRET_KEY=change-me-to-a-50-char-random-string
MY_DEBUG=False
# Comma-separated hostnames the site is served from (no scheme). Required.
ALLOWED_HOSTS=imboni.example.rw,www.imboni.example.rw

# ── Database (PostgreSQL via django-tenants) ──────────────────────────────────
# The DB engine is now PostgreSQL, served through django-tenants (schema-per-
# tenant multi-tenancy). Values below match docker-compose.yml at the repo root.
DATABASE_NAME=imboni        # Database name (matches POSTGRES_DB)
DATABASE_USER=imboni        # Database user (matches POSTGRES_USER)
DATABASE_PASSWORD=imboni    # Database password (matches POSTGRES_PASSWORD)
DATABASE_HOST=127.0.0.1     # Host — 127.0.0.1 when Postgres maps port 5432 locally
DATABASE_PORT=5432          # Port exposed by the Postgres container

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# The deployed frontend URL (used in invitation/reset links).
FRONTEND_URL=https://imboni.example.rw
# Comma-separated origins allowed to call the API in production
# (in DEBUG mode all origins are allowed automatically).
CORS_ALLOWED_ORIGINS=https://imboni.example.rw

# ── HTTPS hardening (only applied when MY_DEBUG=False) ─────────────────────────
# Redirect http→https at the app layer. Leave True unless the proxy already does it.
SECURE_SSL_REDIRECT=True
# HSTS max-age in seconds. Start small (e.g. 3600) when first enabling, then raise.
SECURE_HSTS_SECONDS=31536000

# ── Celery + Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Run tasks inline without a broker (dev only). Leave False in production.
CELERY_TASK_ALWAYS_EAGER=False
# Shared cache for throttle counters across gunicorn workers. Strongly
# recommended in production; leave blank to use a per-process local cache.
REDIS_CACHE_URL=redis://localhost:6379/2

# ── Email ─────────────────────────────────────────────────────────────────────
# Development/testing (MY_DEBUG=True) uses Mailtrap:
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
# Production (MY_DEBUG=False) uses these:
MY_EMAIL_HOST_USER=
MY_EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Imboni School <no-reply@imboni.example.rw>

# ── SMS (Africa's Talking) ────────────────────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=Imboni

# ── Database backups ──────────────────────────────────────────────────────────
# Where `manage.py backup_database` writes snapshots (point at an off-box volume
# in production) and how many days of backups to keep.
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Leave SENTRY_DSN blank to disable Sentry entirely (dev default = no-op).
# Get the DSN from your Sentry project settings. PII is never sent (see settings.py).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Fraction of requests performance-traced (0.0–1.0). Keep low in production.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── School identity / misc ────────────────────────────────────────────────────
SCHOOL_NAME=Imboni School
SCHOOL_EMAIL=
SCHOOL_PHONE=
INVITATION_EXPIRY_DAYS=3
