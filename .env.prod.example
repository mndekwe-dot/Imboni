# Production environment for docker-compose.prod.yml.
# Copy to `.env.prod` (gitignored) and fill in real values, then run:
#   docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# Django
THE_SECRET_KEY=change-me-to-a-long-random-secret
# Leading dot covers every school subdomain, e.g. .imboni.com
ALLOWED_HOSTS=.imboni.com

# Postgres (the same password is used by the db container and the app)
DATABASE_PASSWORD=change-me-strong-db-password

# Optional tuning
GUNICORN_WORKERS=4
CELERY_CONCURRENCY=4
