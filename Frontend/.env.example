# ── Imboni Frontend environment ───────────────────────────────────────────────
# Copy to `.env` and fill in real values (Vite only exposes VITE_-prefixed vars).

# Base URL of the backend API.
VITE_API_BASE=http://localhost:8001

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Leave VITE_SENTRY_DSN blank to disable Sentry entirely (dev default = no-op).
# Set it to the browser DSN from your Sentry project in production.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
# Fraction of transactions performance-traced (0.0–1.0). Keep low in production.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
